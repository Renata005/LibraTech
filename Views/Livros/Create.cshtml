@model LibraTech.Models.Livro

@{
    ViewData["Title"] = "Cadastrar Livro";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📚 Cadastrar Novo Livro</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Titulo" class="form-label">Título</label>
                        <input asp-for="Titulo" class="form-control" />
                        <span asp-validation-for="Titulo" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Autor" class="form-label">Autor</label>
                        <input asp-for="Autor" class="form-control" />
                        <span asp-validation-for="Autor" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="ISBN" class="form-label">ISBN</label>
                        <input asp-for="ISBN" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Editora" class="form-label">Editora</label>
                        <input asp-for="Editora" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="AnoPublicacao" class="form-label">Ano</label>
                        <input asp-for="AnoPublicacao" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoriaId" class="form-label">Categoria</label>
                        <select asp-for="CategoriaId"
                                asp-items="ViewBag.CategoriaId"
                                class="form-select">
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Quantidade" class="form-label">Quantidade</label>
                        <input asp-for="Quantidade" class="form-control" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="CapaUrl" class="form-label">URL da Capa</label>
                        <input asp-for="CapaUrl" class="form-control" placeholder="https://..." />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Sinopse" class="form-label">Sinopse</label>
                        <textarea asp-for="Sinopse"
                                  rows="5"
                                  class="form-control"></textarea>
                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-success">
                    💾 Salvar Livro
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Voltar
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}