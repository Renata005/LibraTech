@model LibraTech.Models.Emprestimo

@{
    ViewData["Title"] = "Novo Empréstimo";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📖 Novo Empréstimo</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="LivroId" class="form-label fw-bold"></label>

                        <select asp-for="LivroId"
                                class="form-select"
                                asp-items="ViewBag.LivroId">

                            <option value="">Selecione um livro</option>

                        </select>

                        <span asp-validation-for="LivroId" class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="UsuarioId" class="form-label fw-bold"></label>

                        <select asp-for="UsuarioId"
                                class="form-select"
                                asp-items="ViewBag.UsuarioId">

                            <option value="">Selecione um usuário</option>

                        </select>

                        <span asp-validation-for="UsuarioId" class="text-danger"></span>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="DataEmprestimo" class="form-label fw-bold"></label>

                        <input asp-for="DataEmprestimo"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="DataEmprestimo" class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="DataDevolucao" class="form-label fw-bold"></label>

                        <input asp-for="DataDevolucao"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="DataDevolucao" class="text-danger"></span>

                    </div>

                </div>

                <div class="form-check mb-4">

                    <input class="form-check-input"
                           asp-for="Devolvido" />

                    <label class="form-check-label"
                           asp-for="Devolvido">
                        Livro já devolvido
                    </label>

                </div>

                <div class="d-flex gap-2">

                    <button type="submit" class="btn btn-primary">

                        💾 Registrar Empréstimo

                    </button>

                    <a asp-action="Index" class="btn btn-secondary">

                        ↩ Voltar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}