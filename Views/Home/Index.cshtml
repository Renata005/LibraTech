@model LibraTech.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Início";
}

<div class="container mt-4">

    <div class="p-5 mb-5 bg-primary text-white rounded shadow">

        <h1 class="display-4">📚 LibraTech</h1>

        <p class="lead">
            Sistema Inteligente de Gerenciamento de Bibliotecas
        </p>

        <hr />

        <p>
            Gerencie livros, usuários e empréstimos de forma simples e moderna.
        </p>

    </div>

    <div class="row mb-5">

        <div class="col-md-3">

            <div class="card text-center shadow">

                <div class="card-body">

                    <h1>📚</h1>

                    <h2>@Model.TotalLivros</h2>

                    <p>Livros</p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-center shadow">

                <div class="card-body">

                    <h1>👤</h1>

                    <h2>@Model.TotalUsuarios</h2>

                    <p>Usuários</p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-center shadow">

                <div class="card-body">

                    <h1>📖</h1>

                    <h2>@Model.EmprestimosAtivos</h2>

                    <p>Empréstimos Ativos</p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card text-center shadow">

                <div class="card-body">

                    <h1>✅</h1>

                    <h2>@Model.LivrosDisponiveis</h2>

                    <p>Livros Disponíveis</p>

                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h1>📚</h1>

                    <h4>Livros</h4>

                    <p>
                        Cadastre e organize o acervo da biblioteca.
                    </p>

                    <a asp-controller="Livros"
                       asp-action="Index"
                       class="btn btn-primary">

                        Acessar

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h1>👤</h1>

                    <h4>Usuários</h4>

                    <p>
                        Gerencie todos os leitores cadastrados.
                    </p>

                    <a asp-controller="Usuarios"
                       asp-action="Index"
                       class="btn btn-success">

                        Acessar

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h1>📖</h1>

                    <h4>Empréstimos</h4>

                    <p>
                        Controle empréstimos e devoluções.
                    </p>

                    <a asp-controller="Emprestimos"
                       asp-action="Index"
                       class="btn btn-warning text-white">

                        Acessar

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>